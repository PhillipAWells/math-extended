#!/bin/sh
# Husky commit-msg hook
# Enforces project policy: no Co-Authored-By lines in commits

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

if echo "$COMMIT_MSG" | grep -q "Co-Authored-By"; then
  cat >&2 <<'EOF'

❌ Commit rejected: Co-Authored-By line found

This project does not use co-authored commits. Each commit must be authored
by a single person or system. See .claude/settings.json for policy configuration.

Please remove the 'Co-Authored-By' line(s) and try again.

EOF
  exit 1
fi

exit 0
