# Normalize line endings to LF on all platforms
* text=auto eol=lf

# ── Source & config — explicitly text ──────────────────────────────────────
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.cjs   text eol=lf
*.mjs   text eol=lf
*.mts   text eol=lf
*.cts   text eol=lf
*.json  text eol=lf
*.jsonc text eol=lf
*.md    text eol=lf
*.mdx   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.svg   text eol=lf
*.sh    text eol=lf eol=lf
*.env   text eol=lf

